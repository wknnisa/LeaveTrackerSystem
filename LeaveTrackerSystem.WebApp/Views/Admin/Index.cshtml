@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4 mb-5">
    <h2 class="fw-bold text-primary mb-3">Admin Dashboard</h2>
    <p class="text-muted mb-4">Welcome back, @ViewBag.Name 👋</p>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0">
                <div class="card-body">
                    <h6>Total Requests</h6>
                    <h3 class="fw-bold text-primary">@ViewBag.Total</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0">
                <div class="card-body">
                    <h6>Approved</h6>
                    <h3 class="fw-bold text-success">@ViewBag.Approved</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0">
                <div class="card-body">
                    <h6>Pending</h6>
                    <h3 class="fw-bold text-warning">@ViewBag.Pending</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0">
                <div class="card-body">
                    <h6>Rejected</h6>
                    <h3 class="fw-bold text-danger">@ViewBag.Rejected</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="fw-semibold text-center mb-3">Leave Requests by Type</h5>
            <canvas id="typeChart" style="max-width: 700px; margin: 0 auto;"></canvas>
        </div>
    </div>

    <div class="text-center d-md-none">
        <a asp-action="AllRequests" class="btn btn-outline-primary px-4">View All Requests</a>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/dist/chart.umd.js"></script>
    <script>
        const labels = JSON.parse('@Html.Raw(ViewBag.LabelsJson ?? "[]")');
        const data = JSON.parse('@Html.Raw(ViewBag.DataJson ?? "[]")');

        new Chart(document.getElementById('typeChart'), {
            type: 'pie',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6610f2']
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    </script>
}