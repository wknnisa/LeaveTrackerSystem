@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .cursor-pointer {
        cursor: pointer;
        transition: 0.2s ease;
    }

        .cursor-pointer:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 24px rgba(0,0,0,0.12);
        }

    a.text-decoration-none {
        color: inherit;
    }

    .card {
        border-radius: 12px;
    }

    .card-body {
        min-height: 110px;
    }

    .empty-state {
        border: 1px dashed #dee2e6;
        border-radius: 10px;
        background-color: #f8f9fa;
        width: 100%;
        padding: 40px 20px;
    }

        .empty-state:hover {
            border-color: #0d6efd;
        }
</style>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary mb-0">@LangHelper.Get(Context, "AdminDashboard")</h2>
    </div>
    <p class="text-muted mb-4">@LangHelper.Get(Context, "WelcomeBack") @ViewBag.Name 👋</p>

    <div class="row mb-3">
        <div class="col-md-3">
            <a asp-action="AllRequests" asp-route-page="1" class="text-decoration-none">
                <div class="card text-center shadow-sm border-0 cursor-pointer">
                    <div class="card-body">
                        <h6>@LangHelper.Get(Context, "TotalRequests")</h6>
                        <h3 class="fw-bold text-primary display-6">@ViewBag.Total</h3>
                        <small class="text-muted">@LangHelper.Get(Context, "AllRequests")</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="AllRequests" asp-route-status="Approved" asp-route-page="1" class="text-decoration-none">
                <div class="card text-center shadow-sm border-0 cursor-pointer">
                    <div class="card-body">
                        <h6>@LangHelper.Get(Context, "Approved")</h6>
                        <h3 class="fw-bold text-success display-6">@ViewBag.Approved</h3>
                        <small class="text-muted">@LangHelper.Get(Context, "SuccessfullyApproved")</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="AllRequests" asp-route-status="Pending" asp-route-page="1" class="text-decoration-none">
                <div class="card text-center shadow-sm border-0 cursor-pointer">
                    <div class="card-body">
                        <h6>@LangHelper.Get(Context, "Pending")</h6>
                        <h3 class="fw-bold text-warning display-6">@ViewBag.Pending</h3>
                        <small class="text-muted">@LangHelper.Get(Context, "AwaitingApproval")</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="AllRequests" asp-route-status="Rejected" asp-route-page="1" class="text-decoration-none">
                <div class="card text-center shadow-sm border-0 cursor-pointer">
                    <div class="card-body">
                        <h6>@LangHelper.Get(Context, "Rejected")</h6>
                        <h3 class="fw-bold text-danger display-6">@ViewBag.Rejected</h3>
                        <small class="text-muted">@LangHelper.Get(Context, "NotApproved")</small>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="mt-3">
        <div class="card shadow-sm border-0" style="min-height: 320px;">
            <div class="card-body">
                <h6 class="fw-semibold text-center mb-3">@LangHelper.Get(Context, "LeaveRequestsByType")</h6>
                
                @if (ViewBag.HasPieData == true)
                {
                    <canvas id="typeChart" style="max-height: 300px;"></canvas>
                }
                else
                {
                    <div class="empty-state text-center py-5">
                        <div class="fs-3">📊</div>
                        <div class="fw-semibold mt-2">
                            @LangHelper.Get(Context, "AdminEmptyStateTitle")
                        </div>
                        <small class="text-muted">
                            @LangHelper.Get(Context, "AdminEmptyStateDesc")
                        </small>
                        <div class="mt-3">
                            <a asp-action="AllRequests" class="btn btn-primary btn-sm">
                                @LangHelper.Get(Context, "ViewAllRequests")
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="text-center d-md-none">
        <a class="btn btn-outline-primary px-4" asp-action="AllRequests">@LangHelper.Get(Context, "ViewAllRequests")</a>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/dist/chart.umd.js"></script>
    <script>
        const labels = JSON.parse('@Html.Raw(ViewBag.LabelsJson ?? "[]")');
        const data = JSON.parse('@Html.Raw(ViewBag.DataJson ?? "[]")');

        const ctx = document.getElementById('typeChart');
        if (ctx && data.length > 0 && data.some(x => x > 0))
        {
            new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6610f2']
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }
    </script>
}