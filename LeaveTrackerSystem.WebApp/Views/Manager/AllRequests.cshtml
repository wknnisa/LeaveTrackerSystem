@model List<LeaveTrackerSystem.Domain.Entities.LeaveRequest>

@{
    ViewData["Title"] = "Pending Leave Requests";
}

<style>
    .bg-warning.text-white {
        background-color: #e0a800 !important;
    }
</style>

<div class="container mt-4 mb-5">
    <h3 class="fw-bold text-primary mb-4">@LangHelper.Get(Context, "PendingLeaveRequests")</h3>

    <form method="get" asp-action="AllRequests" class="mb-4">
        <div class="d-flex align-items-center gap-2">
            <label for="status" class="form-label mb-0 fw-semibold">@LangHelper.Get(Context, "FilterByStatus")</label>
            @Html.DropDownList("status", (List<SelectListItem>)ViewBag.StatusOptions, new {
            @class = "form-select w-auto d-inline-block", onchange = "this.form.submit();"
                        })
        </div>
    </form>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle text-center">
                <thead class="table-light">
                    <tr>
                        <th>@LangHelper.Get(Context, "Email")</th>
                        <th>@LangHelper.Get(Context, "LeaveType")</th>
                        <th>@LangHelper.Get(Context, "StartDate")</th>
                        <th>@LangHelper.Get(Context, "EndDate")</th>
                        <th>@LangHelper.Get(Context, "Reason")</th>
                        <th>@LangHelper.Get(Context, "Status")</th>
                        <th>@LangHelper.Get(Context, "Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td>@request.User.Email</td>
                            <td>@(request.LeaveType.Name ?? LangHelper.Get(Context, "Other"))</td>
                            <td>@request.StartDate.ToShortDateString()</td>
                            <td>@request.EndDate.ToShortDateString()</td>
                            <td>@request.Reason</td>
                            <td>
                                <span class="badge @(request.Status == LeaveStatus.Approved ? "bg-success" : request.Status == LeaveStatus.Rejected ? "bg-danger" : "bg-warning text-white")">
                                    @LangHelper.Get(Context, request.Status.ToString())
                                </span>
                            </td>
                            <td>
                                @if (request.Status == LeaveStatus.Pending)
                                {
                                    <div class="d-flex justify-content-center gap-2">
                                        <form method="post" asp-action="Approve" asp-route-id="@request.Id">
                                            <button type="submit" class="btn btn-success btn-sm rounded-2">@LangHelper.Get(Context, "Approve")</button>
                                        </form>
                                        <form method="post" asp-action="Reject" asp-route-id="@request.Id">
                                            <button type="submit" class="btn btn-danger btn-sm rounded-2">@LangHelper.Get(Context, "Reject")</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center mt-4">@LangHelper.Get(Context, "NoRequestsFound")</div>
    }
</div>