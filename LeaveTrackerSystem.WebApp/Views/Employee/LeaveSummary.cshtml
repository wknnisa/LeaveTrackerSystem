@model Dictionary<string, (int used, int remaining)>

@{
    ViewData["Title"] = "Leave Summary";
}

<style>
    .chart-container {
        width: 100%;
        margin: 0 auto;
        max-width: 700px;
    }

    .chart-placeholder {
        display: block;
        width: 100%;
        margin: 0 auto;
        padding: 15px 0;
        min-height: 60px;
    }
</style>

<div class="d-flex align-items-center mb-4">
    <img src="~/img/LeaveTrackerLogo.png" alt="LogoIpsum Company Logo" class="img-fluid me-3" style="height: 60px;">
    <div>
        <h1 class="mb-0">LogoIpsum HRIS</h1>
        <small class="text-muted mb-0">@LangHelper.Get(Context, "LeaveSummaryReports")</small>
    </div>
</div>

<hr class="mb-4"/>

<div class="container">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">@LangHelper.Get(Context, "LeaveSummaryByType")</h2>
        <div>
            <a href="@Url.Action("ExportSummary", "Employee")" class="btn btn-outline-primary ms-3">@LangHelper.Get(Context, "DownloadPDF")</a>
        </div>
    </div>

    <table class="table table-striped">
        <thead class="table-dark text-center">
            <tr>
                <th>@LangHelper.Get(Context, "LeaveType")</th>
                <th>@LangHelper.Get(Context, "Used")</th>
                <th>@LangHelper.Get(Context, "Remaining")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Key</td>
                        <td class="text-center">@item.Value.used</td>
                        <td class="text-center">@item.Value.remaining</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center text-muted"> @LangHelper.Get(Context, "NoLeaveData")</td>
                </tr>
            }
        </tbody>
    </table>

    @{
        bool hasPieData = ViewBag.LabelsJson?.ToString() != "[]" && ViewBag.DataJson.ToString() != "[]";
        bool hasBarData = ViewBag.BarLabelsJson.ToString() != "[]" && ViewBag.BarDataJson.ToString() != "[]";
    }

    <h3>@LangHelper.Get(Context, "LeaveUsageBreakdown")</h3>
    <div id="pieContainer" class="chart-container">
        @if (hasPieData)
        {
            <canvas id="leavePieChart" height="300"></canvas>
        }
        else
        {
            <div class="alert alert-info text-center chart-placeholder">
                @LangHelper.Get(Context, "NoPieData")
            </div>
        }
    </div>

    <h3>@LangHelper.Get(Context, "LeaveRequestsPerMonth")</h3>
    <div id="barContainer" class="chart-container">
        @if (hasBarData)
        {
            <canvas id="leaveBarChart" height="300"></canvas>
        }
        else
        {
            <div class="alert alert-info text-center chart-placeholder">
                @LangHelper.Get(Context, "NoBarData")
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const labels = JSON.parse('@Html.Raw(ViewBag.LabelsJson ?? "[]")');
        const data = JSON.parse('@Html.Raw(ViewBag.DataJson ?? "[]")');

        let total = 0;
        for (let i = 0; i < data.length; i++) {
            total += data[i];
        }

        if (labels.length === 0 || data.length === 0 || total === 0)
        {
            document.getElementById("pieContainer").innerHTML = "<div class='alert alert-info text-center chart-placeholder'>@LangHelper.Get(Context, "NoPieData")</div>";
        }
        else
        {
            const ctx = document.getElementById('leavePieChart').getContext('2d');
            new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: labels,
                    datasets: [{
                        label: '@LangHelper.Get(Context, "LeaveUsed")',
                        data: data,
                        backgroundColor: ['#36A2EB', '#FF6384', '#FFCE56'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                        },
                        title: {
                            display: true,
                            text: '@LangHelper.Get(Context, "LeaveUsageBreakdown")'
                        }
                    }
                }
            });
        }

        const barLabels = JSON.parse('@Html.Raw(ViewBag.BarLabelsJson ?? "[]")');
        const barData = JSON.parse('@Html.Raw(ViewBag.BarDataJson ?? "[]")');

        let barTotal = 0;

        for (let i = 0; i < barData.length; i++) {
            barTotal += barData[i];
        }

        if (barLabels.length === 0 || barData.length === 0 || barTotal === 0)
        {
            document.getElementById("barContainer").innerHTML = "<div class='alert alert-info text-center chart-placeholder'>@LangHelper.Get(Context, "NoBarData")</div>";
        }
        else
        {
            const barCtx = document.getElementById('leaveBarChart').getContext('2d');
            new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: barLabels,
                    datasets: [{
                        label: '@LangHelper.Get(Context, "ApprovedLeaveRequests")',
                        data: barData,
                        backgroundColor: '#36A2EB'
                    }]
                },
               options: {
                   responsive: true,
                   plugins: {
                        legend: { display: false },
                        title: {
                            display: true,
                            text: '@LangHelper.Get(Context, "MonthlyLeaveUsage")'
                        }
                   },
                   scales: {
                       y: {
                           beginAtZero: true,
                           precision: 0
                       }
                   }
               }
            });
        }
    </script>
}