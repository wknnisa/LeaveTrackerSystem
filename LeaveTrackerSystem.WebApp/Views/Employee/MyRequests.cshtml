@model List<LeaveTrackerSystem.Domain.Entities.LeaveRequest>

@{
    ViewData["Title"] = "My Leave Requests";
}
<div class="container mt-4 mb-5">
    <h3 class="fw-bold text-primary mb-4">@LangHelper.Get(Context, "MyLeaveRequests")</h3>

    <form method="get" asp-action="MyRequests" class="mb-4">
        <div class="d-flex align-items-center gap-2">
            <label for="status" class="form-label mb-0 fw-semibold">@LangHelper.Get(Context, "FilterByStatus")</label>
            @Html.DropDownList("status", (List<SelectListItem>)ViewBag.StatusOptions, new {
            @class = "form-select w-auto", onchange = "this.form.submit();"
            })
        </div>
    </form>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@LangHelper.Get(Context, "LeaveType")</th>
                        <th>@LangHelper.Get(Context, "StartDate")</th>
                        <th>@LangHelper.Get(Context, "EndDate")</th>
                        <th>@LangHelper.Get(Context, "Reason")</th>
                        <th>@LangHelper.Get(Context, "Status")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td>@(request.LeaveType?.Name ?? LangHelper.Get(Context, "Other"))</td>
                            <td>@request.StartDate.ToShortDateString()</td>
                            <td>@request.EndDate.ToShortDateString()</td>
                            <td>@request.Reason</td>
                            <td>
                                <span class="badge @(request.Status == LeaveStatus.Approved ? "bg-success" : request.Status == LeaveStatus.Rejected ? "bg-danger" : "bg-warning text-dark")">
                                    @LangHelper.Get(Context, request.Status.ToString())
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center mt-4">@LangHelper.Get(Context, "NoRequestsFound")</div>
    }
</div>
<div class="d-flex justify-content-center mt-3">

    @if (ViewBag.Page > 1)
    {
         <a asp-action="MyRequests" asp-route-page="@(ViewBag.Page - 1)" asp-route-status="@ViewBag.Status" 
         class="btn btn-outline-secondary me-2">Previous</a>
    }
   
    <span class="badge bg-primary align-self-center px-3 py-2">Page @ViewBag.Page</span>

    @if (ViewBag.HasNextPage)
    {
        <a asp-action="MyRequests" asp-route-page="@(ViewBag.Page + 1)" asp-route-status="@ViewBag.Status" class="btn btn-outline-secondary ms-2">Next</a>
    }
   
</div>