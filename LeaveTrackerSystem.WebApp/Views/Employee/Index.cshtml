
@{
    ViewData["Title"] = "Employee Dashboard";
}

<div class="container mt-4 mb-5">
    <h2 class="fw-bold text-primary mb-3">Employee Dashboard</h2>
    <p class="text-muted mb-4">Welcome back, @ViewBag.Name 👋</p>

    <div class="alert alert-info py-2 shadow-sm mb-4">
        <strong>Annual Leave:</strong> @ViewBag.LeaveBalance
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0">
                <div class="card-body">
                    <h6>Total Requests</h6>
                    <h3 class="fw-bold text-primary">@ViewBag.TotalRequests</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0">
                <div class="card-body">
                    <h6>Approved</h6>
                    <h3 class="fw-bold text-success">@ViewBag.Approved</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0">
                <div class="card-body">
                    <h6>Pending</h6>
                    <h3 class="fw-bold text-warning">@ViewBag.Pending</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0">
                <div class="card-body">
                    <h6>Rejected</h6>
                    <h3 class="fw-bold text-danger">@ViewBag.Rejected</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h6 class="fw-semibold text-center mb-3">Leave Usage By Type</h6>
            <canvas id="leaveChart" style="max-height: 300px;"></canvas>
        </div>
    </div>

    <div class="text-center d-md-none">
        <a class="btn btn-outline-primary px-4" asp-action="MyRequests">View My Requests</a>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/dist/chart.umd.js"></script>
    <script>
        const labels = JSON.parse('@Html.Raw(ViewBag.LabelsJson ?? "[]")');
        const data = JSON.parse('@Html.Raw(ViewBag.DataJson ?? "[]")');

        const ctx = document.getElementById('leaveChart');
        if (ctx)
        {
            new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6610f2']
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom'}
                    }
                }
            });
        }
    </script>
}